{
  "version": 2,
  "routes": [
    {
      "src": "/api/slots",
      "methods": ["OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "https://jaac.io",
        "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type",
        "Access-Control-Max-Age": "86400"
      },
      "dest": "/api/slots.js"
    },
    {
      "src": "/api/book",
      "methods": ["OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "https://jaac.io",
        "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type",
        "Access-Control-Max-Age": "86400"
      },
      "dest": "/api/book.js"
    },
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "https://jaac.io",
        "Access-Control-Allow-Methods": "GET,POST,OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type"
      },
      "dest": "/api/$1.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/auth.js"
    }
  ]
}
